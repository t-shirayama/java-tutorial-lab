    "highlight.js": "^11.11.1",
    "lucide-react": "^0.561.0",
    "markdown-it": "^14.1.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
